---
layout: layouts/page.njk
title: Posts
tags: []
permalink: /posts/
---
<ul class="collection-list">
{% for post in collections.posts | reverse %}
  <li>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <p class="meta">{{ post.data.date | readableDate }}</p>
  </li>
{% endfor %}
</ul>
